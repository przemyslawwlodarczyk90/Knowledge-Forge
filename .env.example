# ============================================================
# PRZYKŁADOWY PLIK KONFIGURACJI — skopiuj jako .env
# NIE wklejaj prawdziwych kluczy do tego pliku (.env.example
# jest w repo, .env NIE jest — patrz .gitignore)
# ============================================================

# OpenAI API — generuj na https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# JWT
JWT_SECRET=yourSuperSecretKeyThatIsAtLeast32CharactersLong

# Baza danych
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/pgDB
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=password
